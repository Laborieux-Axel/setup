{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "ls *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    },
    "external_directory": {
      "~/**": "allow"
    }
  },
  "provider": {
    "ollama": {
      "name": "(Ollama)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "OLLAMA-MODEL-NAME": {
          "name": "OPENCODE-MODEL-NAME",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "vllm": {
      "name": "(vLLM)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "SERVED-MODEL-NAME": {
          "name": "OPENCODE-MODEL-NAME"
        }
      }
    }
  },
  "model": "SERVED-MODEL-NAME",
  "mcp": {
    "arxiv-mcp-server": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "arxiv-mcp-server",
        "--storage-path",
        "/home/shared/arxiv-mcp-server/papers"
      ]
    }
  },
  "tools": {
    "arxiv-mcp-server": false
  }
}